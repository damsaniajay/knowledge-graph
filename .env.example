NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# LLM flow extraction (ordered feature names → UserStory.flows)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1
USE_LLM_FLOWS=true
# Fast uploads (default on): heuristic flows, no LLM on upload, scoped relink only
UPLOAD_FAST=true
# If true: include full graph JSON in upload API response (slower; UI refetches anyway)
UPLOAD_RETURN_GRAPH=false
# If true: story upload without flows[] creates a proposal; commit via /api/flow-proposals/{id}/commit
FLOW_REQUIRE_APPROVAL=false
